<%# TODO %>
<div class="benefits-tab">
  <div class="row">
    <% if product_rates_available?(@benefit_sponsorship) %>
    <div class="alert alert-info" role="alert">
      <strong><i class="fa fa-exclamation-triangle" aria-hidden="true"></i> <%= Settings.site.late_rates_message %></strong>
    </div>
    <% end %>
    <div class="col-xs-8">
      <h1 class="heading-text">
        <% if @benefit_applications.blank? || (@benefit_applications.coverage_effective.blank? && @benefit_applications.draft_state.present?) %>
          <%= l10n("employers.plan_years.benefits_title_with_draft_py") %>
        <% else %>
          <%= l10n("employers.plan_years.benefits_title") %>
        <% end %>
      </h1>
    </div>
    <div class="col-xs-4">
      <% if site_broker_claim_quoting_enabled? %>
        <% if hide_or_show_claim_quote_button(@employer_profile) %>
          <% claim_warnings, claim_modal_name = benefit_application_claim_quote_warnings(@benefit_applications) %>
          <%= link_to "Claim Quote", "", data: { toggle: "modal", target: "#{claim_modal_name}" }, class: 'btn btn-default btn-block' %>

          <% if claim_warnings.present? %>
            <%= render "benefit_sponsors/profiles/employers/benefit_applications/claim_quote_warnings", warnings: claim_warnings %>
          <% end %>
        <% end %>
      <% end %>
      <%#= pundit_span EmployerProfile,:updateable? %>
        <% if @benefit_applications.present? && add_plan_year_button_business_rule(@benefit_sponsorship, @benefit_applications) %>
        <%= link_to "Add Plan Year", new_benefit_sponsorship_benefit_application_path(@benefit_sponsorship), class: "btn btn-default btn-block mt-1", data: {loading_text: "Loading..."}, onclick:"checkForDraftPlans(this)" %>
        <% end %>
      </span>
    </div>
    <% unless @benefit_applications.blank? || @benefit_applications.published.present? %>
    <% if @employer_profile.renewal_benefit_application.blank? || @employer_profile.active_benefit_application.blank? %>
    <div class="col-xs-12">
      <h4>
        <%= l10n("employers.plan_years.benefits_with_plan") %>
      </h4>
      <h4>
        <%= l10n("employers.plan_years.benefits_with_plan.important") %>
      </h4>
      <br/>
    </div>
    <% end %>
    <% end %>
  </div>
  <% if @benefit_applications.present? %>
    <% available_years = @benefit_applications.map { |ba| ba.start_on&.year }.compact.uniq.sort.reverse %>
    <% if EnrollRegistry[:employer_broker_ui_enhancements].enabled? %>
      <div class="row mb-3" id="plan-year-filters">
        <div class="col-xs-12">
          <strong><%= l10n('employers.plan_years.filters') %></strong>
        </div>
        <div class="col-xs-3 mt-1">
          <label><%= l10n('employers.plan_years.filter_plan_years') %></label>
          <select id="plan-year-filter" class="form-control">
            <option value="active_and_renewal"><%= l10n('employers.plan_years.filter_active_and_renewal') %></option>
            <% available_years.each do |year| %>
              <option value="<%= year %>"><%= year %></option>
            <% end %>
          </select>
        </div>
        <div class="col-xs-3 mt-1">
          <label><%= l10n('employers.plan_years.filter_sort') %></label>
          <select id="plan-year-sort" class="form-control">
            <option value="desc"><%= l10n('employers.plan_years.filter_sort_descending') %></option>
            <option value="asc"><%= l10n('employers.plan_years.filter_sort_ascending') %></option>
          </select>
        </div>
      </div>
    <% end %>

    <div id="benefit-applications-container">
    <% @benefit_applications.each do |benefit_application| %>
      <div class="row no-buffer module plan-year mt-2" data-year="<%= benefit_application.start_on&.year %>" data-aasm-state="<%= benefit_application.aasm_state %>">
        <div class="col-xs-8" style="overflow: hidden; margin-bottom: 15px; padding-left: 0;">
          <h3 class="no-buffer heading-text">
            <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 10px;">
              <span data-toggle="tooltip" title="<%= benefit_application.aasm_state.to_s.humanize.titleize %>">
                <% if benefit_application.draft? %>
                <i class="fa fa-file"></i>
                <% elsif benefit_application.enrollment_open? %>
                <i class="fa fa-star enrolling"></i>
                <% elsif benefit_application.approved? %>
                <i class="fa fa-users"></i>
                <% end %>
              </span>
              <div class="mr-1" style="display: inline-block; vertical-align: middle;">
                <%= benefit_application.start_on.to_date.year %>
              </div>
              <% state = benefit_application_summarized_state(benefit_application)%>
              <% styling_info = benefit_application_state_styling(state)%>
              <div class="cylinder-benefit-application-state" style="<%= styling_info[:style] %>">
                <% if styling_info[:icon_class].present? %>
                  <i class="<%= styling_info[:icon_class]%> mr-1" style="<%= styling_info[:icon_style]%>"></i>
                <% elsif styling_info[:img_source].present?%>
                  <img src="<%= styling_info[:img_source] %>" class="mr-1" style="margin-bottom: 5px" alt="<%= styling_info[:img_text] %>">
                <% end %>
                <strong><%= state %></strong>
              </div>
              <% if benefit_application.is_starting_soon? %>
                <div class="cylinder-benefit-application-state" style="border: 2px solid #D4AF37; background-color: #FFF9E6;">
                  <i class="fa fa-exclamation-triangle" style="font-size: 14px; margin-right: 6px;"></i>
                  <strong><%= l10n('employers.plan_years.starting_soon') %></strong>
                </div>
              <% end %>
              <% if benefit_application.is_renewing? || (benefit_application.active? && benefit_application.predecessor.present?) %>
                <% renewal_styling = benefit_application_state_styling("expired") %>
                <div class="cylinder-benefit-application-state" style="<%= renewal_styling[:style] %>">
                  <strong><%= l10n('employers.plan_years.renewal') %></strong>
                </div>
              <% end %>
              <% if benefit_application.latest_benefit_application_item&.state&.to_s == "reinstate" %>
                <% styling_info = benefit_application_state_styling("reinstate")%>
                <div class="cylinder-benefit-application-state" style="<%= styling_info[:style] %>">
                  <strong><%= "Reinstated" %></strong>
                </div>
              <% end %>
            </div>
          </h3>
        </div>
        <div class="col-xs-4" style="position: relative; z-index: 10; white-space: nowrap; padding-left: 0; ;padding-right: 0;">
          <%#= pundit_span EmployerProfile, :updateable? %>
          <% if benefit_application.draft? %>
              <%# if benefit_application.overlapping_published_benefit_applications.empty? %>
              <%= link_to "Publish Plan Year &nbsp;<i class='fa fa-users' aria-hidden='true'></i>".html_safe, benefit_sponsorship_benefit_application_submit_application_path(benefit_application.benefit_sponsorship, benefit_application), method: :post, remote: true, class: "btn btn-default", disabled: product_rates_available?(benefit_application.benefit_sponsorship, benefit_application.start_on.to_date) %>
              <%# end %>
              <% if benefit_application.benefit_packages.empty? || benefit_application.benefit_packages.count > 1 %>
                <%= link_to "Edit Plan Year &nbsp;<i class='fas fa-pencil-alt' aria-hidden='true'></i>".html_safe, edit_benefit_sponsorship_benefit_application_path(benefit_application.benefit_sponsorship, benefit_application), class: "btn btn-default"%>
              <% else %>
                <%= link_to "Edit Plan Year &nbsp;<i class='fas fa-pencil-alt' aria-hidden='true'></i>".html_safe, edit_benefit_sponsorship_benefit_application_benefit_package_path(benefit_application.benefit_sponsorship, benefit_application, benefit_application.benefit_packages.first, :show_benefit_application_tile => true), method: :get, class: "btn btn-default"%>
              <% end %>
          <% end %>
          <%#= pundit_span(EmployerProfile, :revert_application?) %>
          <% if current_user.has_hbx_staff_role? && benefit_application.may_revert_application? %>
            <span class="btn btn-default" data-target="#revertBenefitApplication_<%= benefit_application.id %>" data-toggle="modal" style="float: right;>Revert Application</span>
            <%#= link_to "Revert Application", benefit_sponsorship_benefit_application_revert_path(benefit_application.benefit_sponsorship, benefit_application), method: :post, remote: true, class: "btn btn-default pull-right"%>
          <% end %>
        </div>
        <% if benefit_application.draft? && benefit_application.benefit_packages.empty? %>
          <div class="benefit-group">
            <div class="panel benefitgroup col-xs-12">
              <div class="col-xs-11">
                <table>
                  <tr>
                    <td>
                      <header>Coverage Year</header>
                    </td>
                    <td>
                      <p>
                        <%= benefit_application.start_on.to_date.to_formatted_s :long_ordinal %> - <%= benefit_application.end_on.to_date.to_formatted_s :long_ordinal %>
                      </p>
                    </td>

                    <% if benefit_application.terminated_on %>
                      <td>
                          <header>Terminated On</header>
                      </td>
                      <td>
                         <p>
                            <%= benefit_application.terminated_on.to_date.to_formatted_s :long_ordinal %>
                         </p>
                      </td>
                    <%end%>

                  </tr>

                  <tr>
                    <td>
                      <header>Open Enrollment Dates</header>
                    </td>
                    <td>
                      <p>
                        <%= benefit_application.open_enrollment_start_on.to_date.to_formatted_s :long_ordinal %> - <%= benefit_application.open_enrollment_end_on.to_date.to_formatted_s :long_ordinal %>
                      </p>
                    </td>
                  </tr>

                  <tr>
                    <td>
                      <header>FTE Count</header>
                    </td>
                    <td>
                      <p>
                        <%= benefit_application.fte_count %>
                      </p>
                    </td>
                  </tr>

                  <tr>
                    <td>
                      <header>PTE Count</header>
                    </td>
                    <td>
                      <p>
                        <%= benefit_application.pte_count %>
                      </p>
                    </td>
                  </tr>

                  <tr>
                    <td>
                      <header>MSP Count</header>
                    </td>
                    <td>
                      <p>
                        <%= benefit_application.msp_count %>
                      </p>
                    </td>
                  </tr>

                </table>
              </div>
            </div>
          </div>
        <% end %>

        <% benefit_application.benefit_packages.each do |package| %>
          <div class="benefit-group">
            <% # next if package.reference_plan_id.blank? %>

            <% if package.is_default %>
                <% active = 'active' %>
            <% end %>

            <div class="benefit-package">
              <!--             <a class='make_default_benefit_group_link' data-benefit-group-id="<%= package.id %>" data-href="<%#= employers_employer_profile_plan_year_make_default_benefit_group_path(@employer_profile, benefit_application.id) %>" data-plan-year-id="<%= benefit_application.id %>" href="#"
            style='display:none;'></a> -->
              <div class="panel benefitgroup col-xs-12">
                <!--        <div class="col-xs-1">
              <i class="make-default <%= active %> fa fa-star fa-3x" data-toggle="tooltip" title="Make this your default benefit group"></i>
            </div> -->
                <div class="col-xs-12">
                  <section class="col-xs-10">
                    <header class="row">
                      <h3 class="title heading-text">
                        <%= package.display_title  %>
                      </h3>
                      <% if package.description.present? %>
                          <h5 class="description no-buffer"><%= package.description %></h5>
                      <% end %>
                    </header>
                  </section>
                  <div class="col-xs-2 top-view-details" data-id="<%= package.id %>">
                    <button class="nav-toggle row view" id="showhidebutton" onclick="EmployerProfile.viewDetails($(this))">View
                      Details
                      <i class="fa fa-chevron-down fa-lg"></i>
                    </button>
                  </div>
                  <table>
                    <tr>
                      <td>
                        <header>Coverage Year</header>
                      </td>
                      <td>
                        <p>
                          <%= benefit_application.start_on.to_date.to_formatted_s :long_ordinal %> - <%= benefit_application.end_on.to_date.to_formatted_s :long_ordinal %>
                        </p>
                      </td>
                      <% if benefit_application.terminated_on %>
                        <td>
                          <header>Terminated On</header>
                        </td>
                        <td>
                          <p>
                            <%= benefit_application.terminated_on.to_date.to_formatted_s :long_ordinal %>
                          </p>
                        </td>
                      <% end %>
                    </tr>
                    <tr>
                      <td>
                        <header>Eligibility</header>
                      </td>
                      <td>
                        <p>
                          <%= package.probation_period_display_name %>
                        </p>
                      </td>
                    </tr>
                  </table>
                  <% if EnrollRegistry[:employer_broker_ui_enhancements].enabled? && benefit_application.has_changes_on_renewal? %>
                    <p>
                      <%= image_tag('Status.svg', class: 'change-on-renewal-icon') %> <%= l10n('employers.plan_years.change_on_renewal') %>
                    </p>
                    <% reasons = package.renewal_change_reasons %>
                    <% if reasons.present? %>
                      <ul style="margin-top: -5px; font-size: 13px; color: #666; padding-left: 20px;">
                        <% reasons.each do |reason| %>
                          <li><%= l10n("employers.plan_years.renewal_change_#{reason}") %></li>
                        <% end %>
                      </ul>
                    <% end %>
                  <% end %>
                </div>
              </div>

              <% package.sponsored_benefits.each do |sponsored_benefit| %>
                <%= render 'sponsored_benefit', sponsored_benefit: sponsored_benefit %>
              <% end %>


              <br class="clear"/>
            </div>
            <%= pundit_span @employer_profile, :updateable? %>
            <div class="below clear">
              <%= link_to "Delete Benefit Package <i class='fas fa-trash-alt' aria-hidden='true'></i> ".html_safe, "", data: {toggle: "modal", target: "#deleteBenefitPackageModal-#{package.id.to_s}"}, class: 'btn btn-default' if benefit_application.aasm_state.to_s == "draft" || benefit_application.aasm_state.to_s == "renewing_draft" %>
              <%= render partial: "benefit_sponsors/profiles/employers/benefit_packages/delete_benefit_package_modal", locals: {benefit_application: benefit_application, package: package} if benefit_application.aasm_state.to_s == "draft" || benefit_application.aasm_state.to_s == "renewing_draft" %>
            </div>
            </span>
          </div>
        <% end %>
        <br/>
        <br/>

        <div class="col-xs-12"></div>

        <%= render "benefit_sponsors/benefit_applications/benefit_applications/submit_application_modal", benefit_application: benefit_application %>
        <%= render "benefit_sponsors/benefit_applications/benefit_applications/revert_application_modal", benefit_application: benefit_application %>
      </div>
    <% end %>
    </div>
  <% else %>
      <h4>
        <%=l10n("employers.plan_years.benefits_without_plan")%>
      </h4>
      <br/>
      <%=pundit_span @employer_profile, :updateable?%>
        <%= link_to "Add Plan Year", new_benefit_sponsorship_benefit_application_path(@benefit_sponsorship, tab: 'benefits'), class: "btn btn-primary btn-br", data: {loading_text: "Loading..."}, id:'AddPlanYearBtn' %>
      </span>
  <% end %>
  </div>

<%= render "benefit_sponsors/profiles/employers/benefit_applications/claim_quote_modal" %>

<script>
  function checkForDraftPlans(element) {
    if (true) {
      event.preventDefault()
      swal({
        title: "Warning",
        text: "If you choose to continue any previous draft/ineligible plan years will be canceled",
        icon: "warning",
        buttons: true,
        dangerMode: true
      })
      .then((willDelete) => {
        if (willDelete) {
          window.location.href = "<%= new_benefit_sponsorship_benefit_application_path(@benefit_sponsorship) %>"
        } else {
          element.innerHTML = "Add Plan Year";
          element.classList.remove('disabled');
          element.removeAttribute('disabled')
        }
      });
    }
  }

  var ACTIVE_AND_RENEWAL_STATES = [
    'draft', 'imported', 'pending', 'assigned', 'processing', 'reviewing',
    'information_needed', 'appealing', 'approved', 'enrollment_open',
    'enrollment_extended', 'enrollment_closed', 'binder_paid', 'enrollment_eligible',
    'enrollment_ineligible', 'active', 'termination_pending', 'terminated', 'reinstated'
  ];

  function applyPlanYearFilters() {
    var filterEl = document.getElementById('plan-year-filter');
    var sortEl = document.getElementById('plan-year-sort');
    if (!filterEl || !sortEl) return;

    var filterValue = filterEl.value;
    var sortValue = sortEl.value;
    var currentYear = new Date().getFullYear();
    var container = document.getElementById('benefit-applications-container');
    if (!container) return;

    var planYears = Array.from(container.querySelectorAll('.plan-year'));

    planYears.forEach(function(py) {
      var year = parseInt(py.dataset.year);
      var state = py.dataset.aasmState;
      var visible = false;

      if (filterValue === 'active_and_renewal') {
        var isInValidState = ACTIVE_AND_RENEWAL_STATES.indexOf(state) !== -1;
        var isInValidYear = year >= currentYear - 1;
        visible = isInValidYear && isInValidState;
      } else {
        var filterYear = parseInt(filterValue);
        visible = !isNaN(year) && year === filterYear;
      }

      py.style.display = visible ? '' : 'none';
    });

    var visiblePlanYears = planYears.filter(function(py) { return py.style.display !== 'none'; });
    
    visiblePlanYears.sort(function(a, b) {
      var yearA = parseInt(a.dataset.year);
      var yearB = parseInt(b.dataset.year);
      return sortValue === 'desc' ? yearB - yearA : yearA - yearB;
    });

    visiblePlanYears.forEach(function(py) { container.appendChild(py); });
  }

  function attachFilterListeners() {
    var filterEl = document.getElementById('plan-year-filter');
    var sortEl = document.getElementById('plan-year-sort');
    
    if (filterEl) {
      filterEl.onchange = function() {
        applyPlanYearFilters();
      };
    }
    if (sortEl) {
      sortEl.onchange = function() {
        applyPlanYearFilters();
      };
    }
  }

  function initializePlanYearFilters() {
    attachFilterListeners();
    applyPlanYearFilters();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializePlanYearFilters);
  } else {
    initializePlanYearFilters();
  }
</script>
