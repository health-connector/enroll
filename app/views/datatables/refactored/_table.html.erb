<%# Refactored (Pagy + Stimulus) datatable - full-page entry point.
    The chrome partial inside #effective_datatable_wrapper is what Stimulus
    redraws replace; the filter tab bar outside it keeps its JS-managed state
    across redraws, exactly like the legacy stack. %>
<div class="container"
     data-controller="datatable"
     data-datatable-url-value="<%= url %>"
     data-datatable-page-value="<%= pagy.page %>"
     data-datatable-per-value="<%= pagy.limit %>"
     data-datatable-search-value="<%= search %>"
     data-datatable-order-value="<%= order %>"
     data-datatable-dir-value="<%= dir %>">
  <%= render partial: 'datatables/refactored/filter_tabs', locals: { filters: table.filters } if table.filters %>
  <div id="effective_datatable_wrapper" data-datatable-target="wrapper">
    <%= render partial: 'datatables/refactored/chrome',
               locals: { table: table, pagy: pagy, records: records, url: url, search: search, order: order, dir: dir } %>
  </div>
</div>
