<%# Nested filter tab bar. Markup mirrors datatables/shared/_filter.html.erb — the data-scope / data-key / id="Tab:..." / custom_level_N / Filter-<group> class contract that step definitions and the datatable Stimulus controller rely on — without that partial's inline <script> and <style> blocks (tab behavior lives in the Stimulus controller; the level padding rules live in effective_datatable.scss.erb). Level 1 renders unhidden; deeper levels start hidden until a parent tab activates them. %>
<% level = defined?(level) && level || 1 %>
<% if level == 1 %>
   <% ancestors = [] %>
   <% data_scope = filters[:top_scope] %>

   <div class='custom_filter'>
<% end %>

<% filter_group = ancestors.join('-') %>
<br class="<%= 'hide' if level > 1 %> custom_level_<%= level %> Filter-<%= filter_group %>"/>


<div class="btn btn-group  <%= level > 1 && 'hide sub_level' %> custom_level_<%= level %> Filter-<%= filter_group %>" data-scope="<%= data_scope %>" role='group'>
  <% filters[data_scope].each do |filter| %>
    <div class="btn btn-default" data-key="<%= filter[:scope] %>"
    id="Tab:<%= filter_group.present? ? [filter_group, filter[:scope]].join('-') : filter[:scope] %>" title="<%= filter[:title] %>"
    data-action="click->datatable#filterClicked">
      <%= filter[:label] %>
    </div>
  <% end %>
</div>

<% filters[data_scope].each do |filter| %>
  <% new_data_scope = filter[:subfilter] %>
  <% if new_data_scope %>
    <%= render partial: 'datatables/filter_tabs',
       locals: { filters: filters, level: level + 1, ancestors: ancestors + [filter[:scope]], data_scope: new_data_scope } %>
  <% end %>
<% end %>

<% if level == 1 %>
  </div>
<% end %>
